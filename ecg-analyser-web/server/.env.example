# ==============================================================================
# ECG Analyser Web Server - Environment Configuration Template (.env.example)
#
# Copy this file to '.env' in this same directory and fill in your credentials.
# The '.env' file is ignored by Git to prevent leaks.
# ==============================================================================

# Supabase API Credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Service role key (RECOMMENDED over anon key for backend-to-database operations)
# This bypasses RLS and is more secure than using the anon key.
# Get it from: Supabase Dashboard > Project Settings > API > service_role key
# SUPABASE_SERVICE_KEY=your-service-role-key

# JWT Secret - Generate a strong random secret:
#   node -e "require('crypto').randomBytes(48).toString('hex')"
# WARNING: The server will refuse to start if this is not set.
JWT_SECRET=replace-with-a-strong-random-secret

# Comma-separated list of allowed CORS origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://yourdomain.com

# Server port (default: 3001)
PORT=3001

# Keep-Alive Self-Ping (Render free tier)
# On Render, RENDER_EXTERNAL_URL is set automatically — you don't need this.
# Only set SERVER_URL if deploying on a platform that doesn't provide it.
# Example: SERVER_URL=https://your-app.onrender.com
# SERVER_URL=https://your-app.onrender.com
